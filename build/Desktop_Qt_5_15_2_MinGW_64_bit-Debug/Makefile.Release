####### Install

install_schemas: first FORCE
	@if not exist E:$(INSTALL_ROOT:@msyshack@%=%)\QingningComic\qingning\comic\bin mkdir E:$(INSTALL_ROOT:@msyshack@%=%)\QingningComic\qingning\comic\bin & if not exist E:$(INSTALL_ROOT:@msyshack@%=%)\QingningComic\qingning\comic\bin exit 1
	$(QINSTALL) E:\QingningComic\qingning\comic\schemas E:$(INSTALL_ROOT:@msyshack@%=%)\QingningComic\qingning\comic\bin\schemas

uninstall_schemas: FORCE
	-$(DEL_FILE) E:$(INSTALL_ROOT:@msyshack@%=%)\QingningComic\qingning\comic\bin\schemas
	-$(DEL_DIR) E:$(INSTALL_ROOT:@msyshack@%=%)\QingningComic\qingning\comic\bin 


install: install_schemas  FORCE

uninstall: uninstall_schemas  FORCE

FORCE:

