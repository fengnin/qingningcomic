# 青柠漫画配置文件模板
# 复制此文件为 config.ini 并填入您的真实配置
# 注意：config.ini 包含敏感信息，请勿提交到版本控制！

[database]
# MySQL 数据库配置
host = 192.168.xxx.xxx
port = 3306
database = qingning_comic
username = qingning
password = your_password_here

[qwen]
# 阿里云 DashScope Qwen API 配置
# 获取 API Key: https://dashscope.console.aliyun.com/apiKey
apiKey = sk-your-api-key-here
# 模型选择: qwen-turbo, qwen-plus, qwen-max
model = qwen-plus
# 最大重试次数
maxRetries = 3
# 每块最大字符数
maxChunkLength = 8000
# 请求超时（毫秒）
requestTimeout = 300000

[qwenImage]
# 通义万相图像生成 API 配置
# 使用与 Qwen 相同的 API Key（阿里云百炼 DashScope）
# apiKey 可省略，会自动使用 [qwen] 部分的 apiKey
# apiKey = 
# 图像生成模型：
#   wanx2.1-t2i-turbo - 快速版，性价比高（推荐测试使用）
#   wanx2.1-t2i-plus  - 高质量版
#   wan2.7-image-pro  - 功能最强，支持组图生成
generateModel = wanx2.1-t2i-turbo
# 图像编辑模型（局部修改）
editModel = qwen-image-2.0-2026-03-03
# 请求超时（毫秒）
requestTimeout = 120000
# 最大重试次数
maxRetries = 3
# 强制使用占位图（调试用）
forceMock = false

[storage]
# 文件存储配置
# local: 本地存储（开发调试推荐）
# s3: S3 兼容存储（生产环境推荐）

# 存储类型：local 或 s3
type = local

# 本地存储配置（type=local 时使用）
# 图片将保存在此目录下
dataDir = /data/comic

# S3 兼容存储配置（type=s3 时使用）
# Backblaze B2 控制台: https://secure.backblaze.com/b2_buckets.htm

# 服务端点
# Backblaze B2: https://s3.xxx.backblazeb2.com (xxx 为您的区域)

# 存储桶名称
# bucket = your-bucket-name

# Access Key ID（从存储服务控制台获取）
# accessKey = your-access-key-here

# Secret Access Key（从存储服务控制台获取）
# secretKey = your-secret-key-here

# 区域（Backblaze B2 根据创建位置填写）
# region = us-east-1

# 预签名 URL 过期时间（秒），默认 15 分钟
# presignExpiresIn = 900

# ==================== 预签名 API 配置（推荐） ====================
# 使用后端 API 生成预签名 URL，# 优点：更安全（不暴露密钥）、更灵活、低成本

# 预签名 API 端点
# 示例: https://api.example.com/presigned-url
presignApiEndpoint = 

# API 认证 Token（可选，用于身份验证）
authToken =

[demo]
# 演示账号配置，启动时自动创建（若账号已存在则跳过）
# 面试演示时填入，正式部署时可设 enabled = false
enabled = true

[demo.users]
1_username = qingning
1_password = demo123
2_username = interviewer
2_password = demo456
