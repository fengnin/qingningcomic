install_target: first FORCE
	@if not exist E:$(INSTALL_ROOT:@msyshack@%=%)\qt\5.15.2\mingw81_64\tests\tests mkdir E:$(INSTALL_ROOT:@msyshack@%=%)\qt\5.15.2\mingw81_64\tests\tests & if not exist E:$(INSTALL_ROOT:@msyshack@%=%)\qt\5.15.2\mingw81_64\tests\tests exit 1
	-$(INSTALL_FILE) $(DESTDIR_TARGET) E:$(INSTALL_ROOT:@msyshack@%=%)\qt\5.15.2\mingw81_64\tests\tests\$(TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) E:$(INSTALL_ROOT:@msyshack@%=%)\qt\5.15.2\mingw81_64\tests\tests\$(TARGET)
	-$(DEL_DIR) E:$(INSTALL_ROOT:@msyshack@%=%)\qt\5.15.2\mingw81_64\tests\tests 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

